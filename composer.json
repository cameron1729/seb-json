{
    "name": "cameron1729/seb-json",
    "description": "Encode PHP values as Safe Exam Browser SEB-JSON for Config Key generation.",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "homepage": "https://github.com/cameron1729/seb-json",
    "keywords": [
        "safe-exam-browser",
        "seb",
        "seb-json",
        "config-key",
        "encoder"
    ],
    "authors": [
        {
            "name": "Cameron Ball",
            "email": "cameron@cameron1729.xyz",
            "homepage": "https://cameron1729.xyz"
        }
    ],
    "support": {
        "issues": "https://github.com/cameron1729/seb-json/issues",
        "source": "https://github.com/cameron1729/seb-json"
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "ext-simplexml": "*",
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0 || ^13.0",
        "squizlabs/php_codesniffer": "^3.13 || ^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "cameron1729\\SebJson\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "cameron1729\\SebJson\\Tests\\": "tests/",
            "cameron1729\\SebJson\\Tools\\": "tools/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --no-progress --debug",
        "coverage": [
            "phpunit --coverage-clover /tmp/seb-json-coverage.xml --coverage-text --coverage-filter src --only-summary-for-coverage-text",
            "php tools/check-coverage.php /tmp/seb-json-coverage.xml 100"
        ],
        "cs": "phpcs",
        "support:check": "php tools/php-support.php check",
        "support:update": "php tools/php-support.php update",
        "test": "phpunit",
        "todos": "php tools/check-todos.php",
        "check": [
            "@cs",
            "@analyse",
            "@test",
            "@support:check",
            "@todos"
        ]
    }
}
